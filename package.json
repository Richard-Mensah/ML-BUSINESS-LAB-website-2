// ═══════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════
let activePhase = 'all';
let expanded = {};
let progress = {};
let activeSidebar = null;

const totalLessons = CURRICULUM.reduce((t,ph)=>t+ph.modules.reduce((mt,m)=>mt+m.lessons.length,0),0);

function loadProgress(){
  try{ const s=localStorage.getItem('mlbl_v3'); if(s) progress=JSON.parse(s); }catch(e){}
}
function saveProgress(){
  try{ localStorage.setItem('mlbl_v3',JSON.stringify(progress)); }catch(e){}
}
function resetProgress(){
  if(!confirm('Reset all progress?')) return;
  progress={}; saveProgress(); updateProgressUI(); render();
}

function toggleDark(){
  document.body.classList.toggle('dark');
  document.querySelector('.btn-dark').textContent = document.body.classList.contains('dark') ? '☀ Light' : '◐ Dark';
}

// ═══════════════════════════════════════════════════════
// PROGRESS UI
// ═══════════════════════════════════════════════════════
function updateProgressUI(){
  const done = Object.values(progress).filter(Boolean).length;
  const pct = Math.round((done/totalLessons)*100);
  document.getElementById('navProg').style.width = pct+'%';
  document.getElementById('navPct').textContent = pct+'%';
  document.getElementById('opFill').style.width = pct+'%';
  document.getElementById('opNum').textContent = done;
  document.getElementById('opSub').textContent = 'of '+totalLessons+' lessons complete';
}

function phaseProgress(ph){
  let t=0,d=0;
  ph.modules.forEach(m=>m.lessons.forEach(l=>{t++;if(progress[`${ph.id}_${m.id}_${l.n}`])d++;}));
  return{t,d,pct:t?Math.round((d/t)*100):0};
}

function toggleLesson(key,el){
  progress[key]=!progress[key];
  saveProgress(); updateProgressUI();
  if(progress[key]){el.classList.add('done');el.textContent='✓';}
  else{el.classList.remove('done');el.textContent='';}
  // update mod done count
  const modId = key.split('_')[1];
  const modCard = document.getElementById('modcard_'+modId);
  if(modCard){
    const phId = key.split('_')[0];
    const ph = CURRICULUM.find(p=>p.id===phId);
    const mod = ph&&ph.modules.find(m=>m.id===modId);
    if(mod){
      const done = mod.lessons.filter(l=>progress[`${phId}_${modId}_${l.n}`]).length;
      const doneEl = modCard.querySelector('.mod-done');
      if(doneEl) doneEl.textContent = done>0?done+' ✓':'';
    }
  }
  // update phase bar
  const phId = key.split('_')[0];
  const ph = CURRICULUM.find(p=>p.id===phId);
  if(ph){
    const pp = phaseProgress(ph);
    const fill = document.getElementById('phfill_'+phId);
    const count = document.getElementById('phcount_'+phId);
    if(fill) fill.style.width=pp.pct+'%';
    if(count) count.textContent=pp.d+'/'+pp.t;
  }
}

// ═══════════════════════════════════════════════════════
// PHASE TABS
// ═══════════════════════════════════════════════════════
function buildTabs(){
  const container = document.getElementById('phaseTabs');
  const tabs = [{id:'all',label:'All phases',color:'#374151'},...CURRICULUM.map(p=>({id:p.id,label:p.label+' · '+p.title,color:p.color}))];
  container.innerHTML = tabs.map(t=>`
    <button class="ptab ${activePhase===t.id?'':'off'}" id="tab_${t.id}"
      style="background:${activePhase===t.id?t.color:''};color:${activePhase===t.id?'#fff':''}"
      onclick="setPhase('${t.id}','${t.color}')">${t.label}</button>
  `).join('');
}
function setPhase(id,color){
  activePhase=id; buildTabs(); render();
}

// ═══════════════════════════════════════════════════════
// DIFF BADGE STYLES
// ═══════════════════════════════════════════════════════
const DIFF={
  Beginner:{bg:'#DCFCE7',text:'#166534'},
  Intermediate:{bg:'#FEF3C7',text:'#92400E'},
  Applied:{bg:'#DBEAFE',text:'#1E40AF'},
  Advanced:{bg:'#F3E8FF',text:'#6B21A8'},
};

// ═══════════════════════════════════════════════════════
// RENDER CURRICULUM
// ═══════════════════════════════════════════════════════
function render(){
  const q = document.getElementById('searchInput').value.toLowerCase();
  const container = document.getElementById('curriculumContainer');

  const filtered = CURRICULUM.map(ph=>({
    ...ph,
    modules: ph.modules.map(m=>({
      ...m,
      lessons: m.lessons.filter(l=>!q||l.title.toLowerCase().includes(q)||m.title.toLowerCase().includes(q)||ph.title.toLowerCase().includes(q))
    })).filter(m=>!q||m.lessons.length>0)
  })).filter(ph=>(activePhase==='all'||ph.id===activePhase)&&(!q||ph.modules.some(m=>m.lessons.length>0)));

  if(!filtered.length){
    container.innerHTML='<div class="no-results">No results found for "'+q+'"</div>';
    return;
  }

  container.innerHTML = filtered.map(ph=>{
    const pp = phaseProgress(ph);
    return `
    <div class="phase-block">
      <div class="phase-header" style="background:${ph.light};border-color:${ph.border}">
        <div class="ph-icon" style="background:${ph.color}">${ph.icon}</div>
        <div class="ph-info">
          <div class="ph-title" style="color:${ph.dark}">${ph.label} · ${ph.title}</div>
          <div class="ph-desc" style="color:${ph.dark}">${ph.desc}</div>
          <div class="ph-meta">
            <span class="ph-meta-text" style="color:${ph.mid}">${ph.weeks} · ${ph.totalVideos} videos · ${ph.modules.length} modules</span>
            <div class="ph-mini-bar">
              <div class="ph-mini-track" style="background:${ph.color}33">
                <div class="ph-mini-fill" id="phfill_${ph.id}" style="width:${pp.pct}%;background:${ph.color}"></div>
              </div>
              <span class="ph-mini-count" id="phcount_${ph.id}" style="color:${ph.mid}">${pp.d}/${pp.t}</span>
            </div>
          </div>
        </div>
      </div>
      <div class="modules-grid">
        ${ph.modules.map(mod=>{
          const isExp = expanded[mod.id];
          const d = DIFF[mod.diff]||DIFF.Beginner;
          const modDone = mod.lessons.filter(l=>progress[`${ph.id}_${mod.id}_${l.n}`]).length;
          return `
          <div class="mod-card ${isExp?'open':''}" id="modcard_${mod.id}">
            <div class="mod-body">
              <div class="mod-top">
                <span class="mod-num">MODULE ${mod.num}</span>
                <span class="diff-badge" style="background:${d.bg};color:${d.text}">${mod.diff}</span>
              </div>
              <div class="mod-title">${mod.title}</div>
              <div class="mod-desc">${mod.desc}</div>
              <div class="mod-footer">
                <span class="mod-count">${mod.lessons.length} lessons</span>
                <span class="mod-done">${modDone>0?modDone+' ✓':''}</span>
                <button class="btn-expand" style="color:${ph.color}" onclick="toggleExpand('${mod.id}',this)">${isExp?'Hide ▲':'Show ▼'}</button>
              </div>
            </div>
            ${isExp?`<div class="lessons-panel">${mod.lessons.map(l=>{
              const key=`${ph.id}_${mod.id}_${l.n}`;
              const done=progress[key];
              const isActive = activeSidebar&&activeSidebar.lesson.title===l.title;
              return `
              <div class="lesson-row ${isActive?'active':''}" style="border-bottom-color:var(--border)">
                <div class="lesson-check ${done?'done':''}" onclick="toggleLesson('${key}',this)">${done?'✓':''}</div>
                <div class="lesson-info">
                  <div class="lesson-title ${done?'done':''}">${l.title}</div>
                  <div class="lesson-dur">${l.dur}</div>
                </div>
                <button class="btn-script" style="color:${isActive?'#fff':ph.color};background:${isActive?ph.color:'transparent'};border-color:${ph.color}"
                  onclick="openScript(${JSON.stringify(l).replace(/"/g,'&quot;')}, '${mod.title}', '${ph.id}', '${ph.color}')">Script ↗</button>
              </div>`;
            }).join('')}</div>`:''}
          </div>`;
        }).join('')}
      </div>
    </div>`;
  }).join('');
}

function toggleExpand(id,btn){
  expanded[id]=!expanded[id];
  const card = document.getElementById('modcard_'+id);
  if(!card) return;
  card.classList.toggle('open',expanded[id]);
  btn.textContent = expanded[id]?'Hide ▲':'Show ▼';
  if(expanded[id]){
    // rebuild just the lessons panel
    render();
  } else {
    const panel = card.querySelector('.lessons-panel');
    if(panel) panel.remove();
    card.classList.remove('open');
  }
}

// ═══════════════════════════════════════════════════════
// SCRIPT GENERATION
// ═══════════════════════════════════════════════════════
function openScript(lesson,modTitle,phaseId,color){
  activeSidebar={lesson,modTitle,phaseId,color};
  const isMobile = window.innerWidth<=768;
  if(isMobile){
    document.getElementById('modalTitle').textContent=lesson.title;
    document.getElementById('modalSub').textContent=modTitle+' · '+lesson.dur;
    showLoadingIn('modalBody',color);
    document.getElementById('mobileModal').style.display='flex';
  } else {
    document.getElementById('sidebarTitle').textContent=lesson.title;
    document.getElementById('sidebarSub').textContent=modTitle+' · '+lesson.dur;
    showLoadingIn('sidebarBody',color);
  }
  render(); // refresh active state
  callAPI(lesson,modTitle,isMobile,color);
}

function showLoadingIn(containerId,color){
  document.getElementById(containerId).innerHTML=`
    <div class="loading-wrap">
      <div class="loading-icon">⚙</div>
      <div class="loading-title">Generating your script...</div>
      <div class="loading-sub">MIT lecture style · timed segments<br/>stage directions · B-roll notes · CTA</div>
      <div class="dots"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
    </div>`;
}

async function callAPI(lesson,modTitle,isMobile,color){
  const targetId = isMobile?'modalBody':'sidebarBody';
  try {
    const res = await fetch('/api/generate',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({prompt:lesson.prompt,title:lesson.title})
    });
    const data = await res.json();
    const text = data.script||'Script generation failed. Please try again.';
    document.getElementById(targetId).innerHTML=`
      <div class="script-content">${escapeHtml(text)}</div>
      <div class="script-actions">
        <button class="btn-copy" onclick="copyScript(this)">Copy script</button>
        <button class="btn-regen" onclick="openScript(${JSON.stringify(lesson).replace(/"/g,'&quot;')},'${modTitle}','','${color}')">Regenerate</button>
      </div>`;
  } catch(e){
    document.getElementById(targetId).innerHTML=`<div style="padding:1rem;color:var(--text2);font-size:13px">Error generating script. Please check your connection and try again.</div>`;
  }
}

function copyScript(btn){
  const content = document.querySelector('.script-content');
  if(content) navigator.clipboard?.writeText(content.textContent);
  btn.textContent='Copied ✓';
  setTimeout(()=>btn.textContent='Copy script',2000);
}

function closeSidebar(){
  activeSidebar=null;
  document.getElementById('sidebarBody').innerHTML=`
    <div class="sidebar-empty">
      <div class="sidebar-empty-icon">📝</div>
      <strong>AI Script Generator</strong><br/><br/>
      Click the <strong>Script ↗</strong> button on any lesson to instantly generate a full MIT-style production script.<br/><br/>
      <span style="font-size:11px;color:var(--text3)">Includes: timed segments · stage directions · spoken dialogue · graphics brief · B-roll notes · CTA</span>
    </div>`;
  document.getElementById('sidebarTitle').textContent='Select any lesson';
  document.getElementById('sidebarSub').textContent='Click "Script ↗" on any lesson to generate';
  render();
}

function closeMobileModal(e){
  if(e.target.id==='mobileModal') document.getElementById('mobileModal').style.display='none';
}

function escapeHtml(str){
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ═══════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════
loadProgress();
buildTabs();
render();
updateProgressUI();
</script>
</body>
</html>
